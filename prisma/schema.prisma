
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id      String @id @default(cuid())
  title   String
  status  String @default("ACTIVE")
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])
}

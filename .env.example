# ── Registry ──────────────────────────────────────────────────────────────────
# Your GitHub username or org (ghcr.io/<GHCR_NAMESPACE>/api)
GHCR_NAMESPACE=your-github-username

# Image tag set by CI; set manually for local testing
IMAGE_TAG=latest

# ── Application ───────────────────────────────────────────────────────────────
# External cloud PostgreSQL — must include sslmode=require
DATABASE_URL=postgresql://user:password@your-cloud-db.postgres.database.azure.com:5432/orbithive?sslmode=require

# Strong random string: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-hex

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# Strong random string used for session signing: openssl rand -hex 32
GRAFANA_SECRET_KEY=replace-with-64-char-random-hex
